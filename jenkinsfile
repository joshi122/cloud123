pipeline {
    agent { label 'jenkins-agent' }

    tools {
        jdk 'java21'
        maven 'maven143'
    }

    stages {

        stage("Cleanup Workspace") {
            steps {
                cleanWs()
            }
        }

        stage("Checkout from SCM") {
            steps {
                git branch: 'main',
                    credentialsId: 'github',
                    url: 'https://github.com/joshi122/cloud123.git'
            }
        }

        stage("Build Application") {
            steps {
                dir('cloud123-java') {
                    sh 'mvn clean compile'
                }
            }
        }

        stage("Test Application") {
            steps {
                dir('cloud123-java') {
                    sh 'mvn test'
                }
            }
        }
    }
}
